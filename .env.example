PORT=3002
NODE_ENV=development

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://borealisterminal.com,https://borealisprotocol.ai,https://borealismark.com,https://borealisacademy.com,https://beacon.borealisprotocol.ai,https://borealis-beacon.pages.dev

# Rate limiting - scan endpoint
SCAN_RATE_LIMIT_WINDOW_MS=900000
SCAN_RATE_LIMIT_MAX=30

# In-memory scan TTL (milliseconds) - 7 days default
SCAN_TTL_MS=604800000

# Fetch timeout for scanning (milliseconds)
FETCH_TIMEOUT_MS=10000

# SQLite database path (Render persistent disk)
DB_PATH=/data/beacon.db

# Email - Resend API key (https://resend.com)
RESEND_API_KEY=re_your_key_here

# Email sender address (must be verified domain in Resend)
EMAIL_FROM=Borealis Beacon <noreply@borealisprotocol.ai>

# Beacon frontend URL (used for confirm links and rescan links in emails)
BEACON_URL=https://beacon.borealisprotocol.ai

# Stripe - secret key for Forge checkout
STRIPE_SECRET_KEY=sk_live_your_key_here

# Stripe - webhook signing secret (from Stripe dashboard > webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

PORT=3002
NODE_ENV=development

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://borealisterminal.com,https://borealisprotocol.ai,https://borealismark.com,https://borealisacademy.com,https://beacon.borealisprotocol.ai

# Rate limiting - scan endpoint
SCAN_RATE_LIMIT_WINDOW_MS=900000
SCAN_RATE_LIMIT_MAX=30

# In-memory scan TTL (milliseconds) - 7 days default
SCAN_TTL_MS=604800000

# Fetch timeout for scanning (milliseconds)
FETCH_TIMEOUT_MS=10000

# Main Borealis API for BTS key issuance
MAIN_API_URL=https://borealismark-api.onrender.com
